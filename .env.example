# ============================================================
# MedBuddy — Environment Variables Template
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- Google / Gemini ---
GOOGLE_API_KEY=
GOOGLE_AI_DEFAULT_MODEL=gemini-2.5-pro

# Google Search (for drug info lookups)
GOOGLE_CSE_ID=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# --- LINE Messaging API ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- Database ---
DATABASE_URL=postgresql+asyncpg://medbuddy:medbuddy@localhost:5432/medbuddy

# --- OpenAI (Whisper STT only) ---
OPENAI_API_KEY=

# --- Google Cloud TTS (zh-TW voice) ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# --- App ---
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

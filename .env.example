# ============================================================
# MedBuddy — Environment Variables Template
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- Google Gemini API (required) ---
GOOGLE_API_KEY=
GOOGLE_AI_DEFAULT_MODEL=gemini-2.5-pro
GOOGLE_AI_FAST_MODEL=gemini-2.5-flash

# --- LINE Messaging API (required) ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- Database ---
DATABASE_URL=postgresql+asyncpg://medbuddy:medbuddy@localhost:5432/medbuddy

# --- Encryption (optional in dev, required in production) ---
# Generate: python -c "import os; print(os.urandom(32).hex())"
AES_ENCRYPTION_KEY=

# --- App ---
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
